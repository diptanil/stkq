; Parser fixture modeled after examples/portfolio.qstock.
; It intentionally covers quoted names, inline comments, all transaction types,
; comment stripping, per-share prices, total prices, dividends, reinvestments, and splits.

format qstock_0.1.0
currency USD

portfolio personal "Personal Portfolio"

account schwab "Charles Schwab" personal USD

account fidelity "Fidelity Brokerage"
  portfolio: personal
  currency: USD

account schwab-ira "Schwab IRA"
  portfolio: personal
  currency: USD

2025-01-15 buy aapl 10 @ 187.35 USD ; lower-case symbols are normalized
  account: fidelity
  fee: 0.00 USD
  note: initial Apple position ; trailing metadata comments are stripped

2025-02-03 buy VOO 3 @@ 4301.20 USD
  account: schwab-ira
  fee: 0.00 USD

2025-03-15 dividend AAPL 12.40 USD
  account: fidelity
  mode: cash

